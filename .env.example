# ── Core API Keys (REQUIRED) ─────────────────────────────────────────────────
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to GitHub

GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
COLLEGE_API_KEY=your_college_scorecard_api_key_here

# ── App Settings ──────────────────────────────────────────────────────────────
PORT=8000
DEBUG=True   # Set to False in production (already the default)

# ── Where to get keys ─────────────────────────────────────────────────────────
# GROQ_API_KEY    → https://console.groq.com
# TAVILY_API_KEY  → https://tavily.com/dashboard
# COLLEGE_API_KEY → https://collegescorecard.ed.gov/data/documentation/
